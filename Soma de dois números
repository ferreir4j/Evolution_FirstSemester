#include <stdio.h>

int main()
{
    int numero1, numero2;
    int soma;

    printf("Digite o primeiro numero: ");
    scanf("%d", &numero1);

    printf("\nDigite o segundo numero: ");
    scanf("%d", &numero2);

    soma = numero1 + numero2;

    printf("\nResultado: %d", soma);

    return 0;
}
