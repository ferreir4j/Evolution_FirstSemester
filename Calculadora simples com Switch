#include <stdio.h>

int main()
{
    float num1, num2, resultado;
    char operador;

    printf("Digite um numero: ");
    scanf("%f", &num1);

    printf("\nDigite um numero: ");
    scanf("%f", &num2);

    printf("\nInforme o operador sendo: \n+ _ Adicao | - _ Subtracao | * _ Multiplicacao | / _ Divisao: ");
    scanf(" %c", &operador);

    switch (operador)
    {
    case '+':
        resultado = num1 + num2;
        printf("\nResultado: %.1f\n", resultado);
        break;

    case '-':
        resultado = num1 - num2;
        printf("\nResultado: %.1f\n", resultado);
        break;

    case '*':
        resultado = num1 * num2;
        printf("\nResultado: %.1f\n", resultado);
        break;

    case '/':
        if(num2 != 0)
        {
            resultado = num1 / num2;
            printf("\nResultado: %.1f\n", resultado);
        }
        else{printf("\nNao existe divisao por zero");}
        break;

    default:
        printf("\nOperacao Invalida!");

    }
   return 0;
}
