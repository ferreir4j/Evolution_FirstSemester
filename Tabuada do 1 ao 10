#include <stdio.h>

int main()
{
    int i, num;

    printf("\t\t--==TABUADA==--\n\n");

    for(num = 1; num <= 5; num++)
    {
        printf("\n\nTABUADA DO %d\t\t\tTABUADA DO %d\n\n", num, num + 5);

        for(i = 1; i <= 10; i++)
        {
            printf("%d x %d = %2d\t\t\t", num, i, num * i);

            printf("%d x %d = %2d\n", num + 5, i, (num + 5) * i);
        }

    }

    return 0;
}
